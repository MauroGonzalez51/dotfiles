#!/usr/bin/env python3

import subprocess
import tempfile
from pathlib import Path
from typing import Set
import argparse


def extract_frame(path: Path) -> Path:
    tmp = tempfile.NamedTemporaryFile(suffix=".jpg", delete=False)
    tmp_path = Path(tmp.name)
    tmp.close()

    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-i",
            str(path),
            "-vframes",
            "1",
            "-q:v",
            "2",
            str(tmp_path),
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return tmp_path


def is_video(
    path: Path, extensions: Set[str] = {".mp4", ".mkv", ".webm", ".mov", ".avi", ".flv"}
) -> bool:
    if path.suffix.lower() not in extensions:
        return False

    try:
        result = subprocess.run(
            [
                "ffprobe",
                "-v",
                "error",
                "-select_streams",
                "v:0",
                "-show_entries",
                "stream=codec_name",
                "-of",
                "default=noprint_wrappers=1:nokey=1",
                str(path.absolute()),
            ],
            capture_output=True,
            text=True,
            timeout=3,
        )
        codec = result.stdout.strip().lower()
        return codec not in ["", "mjpeg", "png"]
    except Exception:
        return False


def apply_wallpaper(path: Path) -> None:
    if not path.exists():
        print("path does not exists")
        return

    if is_video(path=path):
        subprocess.run(["awww", "kill"], capture_output=True)
        subprocess.run(["pkill", "-x", "mpvpaper"], capture_output=True)

        subprocess.Popen(
            [
                "mpvpaper",
                "-f",
                "-o",
                "no-audio loop",
                "*",
                str(path.absolute()),
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        target = extract_frame(path=path)
        subprocess.run(["wallust", "run", str(target.absolute())])
        target.unlink(missing_ok=True)
        return

    subprocess.run(["pkill", "-x", "mpvpaper"], capture_output=True)
    subprocess.run(["awww-daemon"])
    subprocess.run(["awww", "img", str(path.absolute())])
    subprocess.run(["wallust", "run", str(path.absolute())])


def main():
    parser = argparse.ArgumentParser()

    parser.add_argument("--path", metavar="PATH")

    args = parser.parse_args()

    if args.path:
        path = Path(args.path).expanduser().resolve()
        apply_wallpaper(path=path)
        return


if __name__ == "__main__":
    main()
