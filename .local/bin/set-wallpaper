#!/usr/bin/env python3

import subprocess
import tempfile
from pathlib import Path
import sys


def is_video(path: Path) -> bool:
    video_extensions = {".mp4", ".mkv", ".webm", ".mov", ".avi", ".flv"}
    if path.suffix.lower() not in video_extensions:
        return False

    try:
        result = subprocess.run(
            [
                "ffprobe",
                "-v",
                "error",
                "-select_streams",
                "v:0",
                "-show_entries",
                "stream=codec_name",
                "-of",
                "default=noprint_wrappers=1:nokey=1",
                str(path),
            ],
            capture_output=True,
            text=True,
            timeout=3,
        )
        codec = result.stdout.strip().lower()
        return codec not in ["", "mjpeg", "png"]
    except Exception:
        return False


def extract_frame(video_path: Path) -> Path:
    tmp = tempfile.NamedTemporaryFile(suffix=".jpg", delete=False)
    tmp_path = Path(tmp.name)
    tmp.close()

    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-i",
            str(video_path),
            "-vframes",
            "1",
            "-q:v",
            "2",
            str(tmp_path),
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return tmp_path


def main(_path: str):
    path = Path(_path).expanduser().absolute()

    if not path.exists():
        return

    if is_video(path):
        sys.stdout.write(f"using file: {path.absolute()}\n")
        subprocess.run(["awww", "kill"], capture_output=True)
        subprocess.run(["pkill", "-x", "mpvpaper"], capture_output=True)

        subprocess.Popen(
            ["mpvpaper", "-f", "-o", "no-audio loop", "*", str(path.absolute())],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        target = extract_frame(video_path=path)
        subprocess.run(["wallust", "run", str(target.absolute())])
        target.unlink(missing_ok=True)
        return

    subprocess.run(["pkill", "-x", "mpvpaper"], capture_output=True)
    subprocess.run(["awww-daemon"])
    subprocess.run(["awww", "img", str(path.absolute())])
    subprocess.run(["wallust", "run", str(path.absolute())])


if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser()
    parser.add_argument("--path")

    args = parser.parse_args()

    main(_path=args.path)
