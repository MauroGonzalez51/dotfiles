#!/usr/bin/env python3

import os
import json
import argparse
from dataclasses import dataclass
from pathlib import Path
from typing import List, Optional, Dict
import subprocess
import sys

STATE_FILE = "theme-state.json"
CONFIG_FILES = ("config.jsonc", "config.json")
STYLE_FILES = ("style.css", "styles.css")


@dataclass
class Theme:
    label: str
    config_path: Path
    style_path: Path


def reload_waybar() -> None:
    subprocess.run(["pkill", "-USR2", "waybar"], check=False)


def exec_waybar(config_path: Path, style_path: Path) -> None:
    subprocess.Popen(
        [
            "waybar",
            "--config",
            str(config_path.absolute()),
            "--style",
            str(style_path.absolute()),
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
        close_fds=True,
    )


def kill_waybar() -> None:
    subprocess.run(["killall", "waybar"])


def state_path(config_directory: Path) -> Path:
    return config_directory / STATE_FILE


def save_state(config_directory: Path, theme: Theme) -> None:
    payload: Dict[str, str] = {
        "theme": theme.label,
        "config_path": str(theme.config_path.absolute()),
        "style_path": str(theme.style_path.absolute()),
    }

    state_path(config_directory=config_directory).write_text(
        json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8"
    )


def load_state(config_directory: Path) -> Optional[Theme]:
    path = state_path(config_directory=config_directory)
    if not path.exists():
        return None

    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return None

    theme_label = data.get("theme")
    config_path = data.get("config_path")
    style_path = data.get("style_path")
    if not theme_label or not config_path or not style_path:
        return None

    return Theme(
        label=theme_label,
        config_path=Path(config_path),
        style_path=Path(style_path),
    )


def resolve_init(config_directory: Path, themes: List[Theme]) -> Theme:
    saved = load_state(config_directory=config_directory)
    if saved:
        found = find_theme(themes=themes, label=saved.label)
        if found:
            return found

    default = find_theme(themes=themes, label="default")
    if default:
        return default

    return themes[0]


def resolve_config_file(directory: Path) -> Optional[Path]:
    for name in CONFIG_FILES:
        candidate = directory / name
        if candidate.exists():
            return candidate

    return None


def resolve_style_file(directory: Path) -> Optional[Path]:
    for name in STYLE_FILES:
        candidate = directory / name
        if candidate.exists():
            return candidate

    return None


def discover_themes(config_directory: Path) -> List[Theme]:
    themes: List[Theme] = []

    default_config = resolve_config_file(directory=config_directory)
    default_styles = resolve_style_file(directory=config_directory)
    if (
        default_config
        and default_config.exists()
        and default_styles
        and default_styles.exists()
    ):
        themes.append(
            Theme(
                label="Default", config_path=default_config, style_path=default_styles
            )
        )

    themes_directory = config_directory / "themes"
    if themes_directory.exists() and themes_directory.is_dir():
        for theme_directory in sorted(
            p for p in themes_directory.iterdir() if p.is_dir()
        ):
            cfg = resolve_config_file(directory=theme_directory)
            css = resolve_style_file(directory=theme_directory)
            if cfg and cfg.exists() and css and css.exists():
                themes.append(
                    Theme(label=theme_directory.name, config_path=cfg, style_path=css)
                )

    return themes


def find_theme(themes: List[Theme], label: str) -> Optional[Theme]:
    for theme in themes:
        if theme.label.lower() == label.lower():
            return theme
    return None


def main() -> None:
    parser = argparse.ArgumentParser(description="Waybar theme switcher")

    group = parser.add_mutually_exclusive_group()
    group.add_argument("--select", metavar="NAME", help="Select Theme")
    group.add_argument("--select-wofi", action="store_true")
    group.add_argument("--init", action="store_true", help="Init from saved state")
    group.add_argument("--list", action="store_true", help="List available themes")
    group.add_argument(
        "--reload", action="store_true", help="Reload current configuration"
    )

    args = parser.parse_args()

    home = os.getenv("HOME")
    if not home:
        raise SystemExit("could not detect home directory")

    config_directory = Path(home).resolve() / ".config" / "waybar"
    if not config_directory.exists() and not config_directory.is_dir():
        raise SystemExit(f"{config_directory} does not exists")

    themes = discover_themes(config_directory=config_directory)
    if not themes:
        raise SystemExit("no valid themes found")

    if args.list:
        """
        [LIST]
        Just print all the theme labels
        """
        for theme in themes:
            print(theme.label)
        return

    if args.init:
        """
        [INIT]
        Should read config based on the file saved and then init waybar

        Pipeline:
            init > load_state > exec_waybar > exit

            resolve_init = load_state, returns default theme if file cound not be readed
        """

        selected_theme = resolve_init(config_directory=config_directory, themes=themes)
        exec_waybar(
            config_path=selected_theme.config_path, style_path=selected_theme.style_path
        )
        return

    if args.select:
        """
        [SELECT]
        Select a new theme and apply it

        Pipeline:
            discover_themes > find_theme (input)
                > kill waybar > exec_waybar > save_state > exit
                > reload_waybar > save_state > exit
        """

        selected = find_theme(themes=themes, label=args.select)
        if not selected:
            available = ", ".join(t.label for t in themes)
            raise SystemExit(f"theme '{args.select}' not found. available: {available}")

        state = load_state(config_directory=config_directory)
        if state and state.label.lower() == selected.label.lower():
            return

        kill_waybar()
        exec_waybar(config_path=selected.config_path, style_path=selected.style_path)
        save_state(config_directory=config_directory, theme=selected)
        return

    if args.reload:
        """
        [RELOAD]
        Just reload the config
        """
        reload_waybar()
        return

    if args.select_wofi:
        """
        [SELECT_WOFI]
        Use wofi --dmenu to select theme to display

        Pipeline:
            discover_themes > wofi --dmenu (subprocess) > find_theme
                theme && kill_waybar > exec_waybar > save_state
        """
        menu_text = "\n".join([theme.label for theme in themes])

        try:
            result = subprocess.run(
                ["wofi", "--dmenu", "--insensitive", "--allow-images"],
                input=menu_text,
                capture_output=True,
                text=True,
            )

            if result.returncode == 0 and result.stdout.strip():
                choice = result.stdout.strip()

                selected = find_theme(themes=themes, label=choice)

                if selected:
                    state = load_state(config_directory=config_directory)
                    if state and state.label.lower() == selected.label.lower():
                        return

                    kill_waybar()
                    exec_waybar(
                        config_path=selected.config_path, style_path=selected.style_path
                    )
                    save_state(config_directory=config_directory, theme=selected)
        except Exception as exception:
            sys.stderr.write(f"[exception] {exception}\n")


if __name__ == "__main__":
    main()
