{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "/home/arch/.local/share/fastfetch/images/logo.png",
        "type": "auto",
        "height": 14,
        "padding": {
            "top": 4,
            "left": 2
        }
    },
    "display": {
        "separator": " "
    },
    "modules": [
        "break",
        "break",
        "break",
        "break",
        {
            "type": "title",
            "keyWidth": 10,
            "keyColor": "#{{color4 | strip}}"
        },
        "break",
        {
            "type": "os",
            "key": "\udb82\udcc7 ",
            "keyColor": "#{{color4 | strip}}"
        },
        {
            "type": "kernel",
            "key": "\ueb51 ",
            "keyColor": "#{{color4 | strip}}"
        },
        {
            "type": "cpu",
            "key": "\uf4bc ",
            "keyColor": "#{{color4 | strip}}",
            "format": "{}"
        },
        {
            "type": "gpu",
            "key": "\udb83\ude37 ",
            "keyColor": "#{{color4 | strip}}",
            "format": "{} ({})"
        },
        {
            "type": "packages",
            "key": "\ueb29 ",
            "keyColor": "#{{color4 | strip}}",
            "format": "{} (pacman)"
        },
        {
            "type": "shell",
            "key": "\uf120 ",
            "keyColor": "#{{color4 | strip}}"
        },
        {
            "type": "wm",
            "key": "\udb81\udce9 ",
            "keyColor": "#{{color4 | strip}}"
        },
        {
            "type": "uptime",
            "key": "\ue641 ",
            "keyColor": "#{{color4 | strip}}"
        },
        {
            "type": "media",
            "key": "\uec1b ",
            "keyColor": "#{{color4 | strip}}"
        },
        "break"
    ]
}